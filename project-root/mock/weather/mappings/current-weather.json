{
  "request": {
    "method": "GET",
    "urlPath": "/v1/forecast",
    "queryParameters": {
      "latitude": {
        "matches": ".*"
      },
      "longitude": {
        "matches": ".*"
      },
      "current": {
        "equalTo": "temperature_2m,wind_speed_10m,is_day,weather_code"
      }
    }
  },
  "response": {
    "status": 200,
    "headers": {
      "Content-Type": "application/json"
    },
    "jsonBody": {
      "latitude": 55.75,
      "longitude": 37.61,
      "generationtime_ms": 0.22,
      "utc_offset_seconds": 0,
      "timezone": "UTC",
      "timezone_abbreviation": "UTC",
      "elevation": 144.0,
      "current": {
        "time": "2026-03-02T12:00",
        "interval": 900,
        "temperature_2m": 21.5,
        "wind_speed_10m": 12.3,
        "is_day": 1,
        "weather_code": 3
      }
    }
  }
}
